# Frontend (Vite) — copy this file to `.env` in the project root and fill in values.
# Dashboard: https://supabase.com/dashboard → Project Settings → API

# Full project URL (recommended)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Or omit URL and set only the ref (URL becomes https://REF.supabase.co)
# VITE_SUPABASE_PROJECT_ID=your-project-ref

# Public anon key (safe in the browser with RLS enabled)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: override API for child profile comments/meetings (default: localhost in dev, Edge in prod)
# VITE_BACKEND_API_BASE=http://localhost:8000/make-server-8d885905
# Supabase Configuration
DATABASE_URL=https://irqqfedhzzxysdiowuft.supabase.co
DATABASE_SERVICE_ROLE_KEY=postgresql://postgres:[YOUR-PASSWORD]@db.irqqfedhzzxysdiowuft.supabase.co:5432/postgres
PORT=8000

# Public API base URL for the browser (safe to commit — never put service-role keys here).
# Leave unset for same-origin /api (Vite dev proxy in development).
# VITE_API_BASE_URL=https://your-app.vercel.app
