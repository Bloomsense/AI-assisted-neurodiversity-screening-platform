# Supabase JS client (used by api/index.js)
# SUPABASE_URL = https://YOUR_PROJECT_REF.supabase.co
#
# Must be the "service_role" secret key from Dashboard → Project Settings → API
# (long JWT starting with eyJ...). NOT the Postgres connection string.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

PORT=3001
